.hype-worktrees/
/scripts
/project-scripts/

# ─────────────────────────────────────────────────────────────
# Root-level clutter guards
# ─────────────────────────────────────────────────────────────
# Prevent accidental commits of build/test artifacts in project root.
# Leading "/" anchors to repo root — these rules do NOT affect src/**,
# docs/**, or tests/**.
/*.db
/*.db-shm
/*.db-wal
/*.png
/*.jpg
/*.jpeg
/*.mo
/*.pot
/*.session
/*.xml
/*.txt
/MagicMock/

# Ephemeral session reports (anywhere) — these belong in docs/reports/
# if they need to live long-term, not in git root.
/VERIFICATION*.md
/SMOKE_TEST*.md
/TASK_*.md
/MANUAL_*.md
/*.prev.md
/DECISION.md
