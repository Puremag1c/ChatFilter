#: src/chatfilter/telegram/client/loader.py:160
msgid ""
"Session '{session_id}' has no api_id configured. Please configure api_id "
"before connecting."
msgstr ""
"Сессия '{session_id}' не имеет настроенного api_id. Пожалуйста, настройте "
"api_id перед подключением."

