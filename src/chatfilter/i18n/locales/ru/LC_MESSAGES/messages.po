#, python-format
msgid "Rate limit exceeded. Please wait %(duration)s before trying again."
msgstr ""
"Превышен лимит запросов. Пожалуйста, подождите %(duration)s перед повторной "
"попыткой."

#: src/chatfilter/telegram/error_mapping.py:385
#, python-format
msgid "Wait %(duration)s and then click 'Retry'"
msgstr "Подождите %(duration)s и нажмите «Повторить»"

