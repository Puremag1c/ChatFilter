#: src/chatfilter/telegram/client/loader.py:119
#: src/chatfilter/telegram/client/loader.py:225
msgid ""
"Session '{session_id}' has no proxy configured. Please configure a proxy for"
" this session before connecting."
msgstr ""
"Сессия '{session_id}' не имеет настроенного прокси. Пожалуйста, настройте "
"прокси для этой сессии перед подключением."

#: src/chatfilter/telegram/client/loader.py:133
#: src/chatfilter/telegram/client/loader.py:215
msgid ""
"Session '{session_id}' requires proxy '{proxy_id}' which is not found in "
"proxy pool. Please add the proxy to the pool or update the session "
"configuration."
msgstr ""
"Сессия '{session_id}' требует прокси '{proxy_id}', который не найден в пуле "
"прокси. Пожалуйста, добавьте прокси в пул или обновите конфигурацию сессии."

