#: src/chatfilter/telegram/error_mapping.py:501
#: src/chatfilter/telegram/error_mapping.py:540
msgid "Rate limit exceeded. Please wait before trying again."
msgstr ""
"Превышен лимит запросов. Пожалуйста, подождите перед повторной попыткой."

#: src/chatfilter/telegram/error_mapping.py:388
msgid "Wait a few minutes and then click 'Retry'"
msgstr "Подождите несколько минут и нажмите «Повторить»"

#: src/chatfilter/telegram/error_mapping.py:403
#: src/chatfilter/telegram/error_mapping.py:508
#, python-format
msgid ""
"Slow mode is enabled. Please wait %(duration)s before sending another "
"message."
msgstr ""
"Включён медленный режим. Пожалуйста, подождите %(duration)s перед отправкой "
"следующего сообщения."

#: src/chatfilter/telegram/error_mapping.py:406
#, python-format
msgid "Wait %(duration)s before trying again"
msgstr "Подождите %(duration)s перед повторной попыткой"

#: src/chatfilter/telegram/error_mapping.py:409
#: src/chatfilter/telegram/error_mapping.py:512
msgid "Slow mode is enabled. Please wait before sending another message."
msgstr ""
"Включён медленный режим. Пожалуйста, подождите перед отправкой следующего "
"сообщения."

#: src/chatfilter/telegram/error_mapping.py:411
msgid "Wait for the slow mode cooldown before trying again"
msgstr ""
"Дождитесь окончания периода ожидания медленного режима перед повторной "
"попыткой"

#: src/chatfilter/telegram/error_mapping.py:429
msgid "action"
msgstr "Действия"

#: src/chatfilter/telegram/error_mapping.py:438
msgid "Check your internet connection and click 'Retry'"
msgstr "Пожалуйста, проверьте соединение и попробуйте снова."

#: src/chatfilter/telegram/error_mapping.py:442
msgid "Upload a new session file from your Sessions page"
msgstr "Загрузите новый файл сессии со страницы «Сессии»"

#: src/chatfilter/telegram/error_mapping.py:446
msgid "Try a different chat or verify your access permissions"
msgstr "Попробуйте другой чат или проверьте права доступа"

#: src/chatfilter/telegram/error_mapping.py:450
msgid "Check your input and try again with correct information"
msgstr ""
"Проверьте введённые данные и попробуйте снова с правильной информацией"

#: src/chatfilter/telegram/error_mapping.py:454
msgid "Wait a few minutes and click 'Retry'"
msgstr "Подождите несколько минут и нажмите «Повторить»"

#: src/chatfilter/telegram/error_mapping.py:458
msgid "Try again or contact support if the issue persists"
msgstr ""
"Повторите попытку или обратитесь в поддержку, если проблема сохраняется"

#: src/chatfilter/telegram/error_mapping.py:545
msgid "Your session has expired. Please log in again with a new session file."
msgstr "Ваша сессия истекла. Пожалуйста, войдите снова с новым файлом сессии."

#: src/chatfilter/telegram/error_mapping.py:548
msgid "Access denied. You may have been banned or removed from this chat."
msgstr ""
"Доступ запрещён. Возможно, вы были заблокированы или удалены из этого чата."

#: src/chatfilter/telegram/error_mapping.py:551
msgid "Access to this resource is restricted."
msgstr "Доступ к этому ресурсу ограничен."

#: src/chatfilter/telegram/error_mapping.py:554
msgid "Request timed out. Please try again."
msgstr "Пожалуйста, попробуйте снова."

#: src/chatfilter/telegram/error_mapping.py:557
msgid ""
"Network connection error. Please check your internet connection and try "
"again."
msgstr "Пожалуйста, проверьте соединение и попробуйте снова."

#: src/chatfilter/telegram/error_mapping.py:562
msgid "Chat or user not found. Please verify the information is correct."
msgstr ""
"Чат или пользователь не найден. Пожалуйста, проверьте правильность "
"информации."

#: src/chatfilter/telegram/error_mapping.py:566
#, python-format
msgid ""
"An error occurred: %(error_class)s. Please try again or contact support if "
"the issue persists."
msgstr ""
"Произошла ошибка: %(error_class)s. Пожалуйста, повторите попытку или "
"обратитесь в поддержку."

